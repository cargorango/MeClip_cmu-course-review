// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  displayName       String
  password          String?      // null for Google OAuth users
  role              Role         @default(STUDENT)
  isAnonymous       Boolean      @default(false)
  status            UserStatus?
  yearOfStudy       Int?
  degreeLevel       DegreeLevel? // new: ระดับปริญญา (นักศึกษา)
  faculty           String?      // new: คณะ (อาจารย์)
  alumniYear        Int?         // new: รุ่นที่จบ (ศิษย์เก่า)
  isProfileComplete Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  ratings       DifficultyRating[]
  messages      Message[]
  reports       Report[]
  auditLogs     AuditLog[]       @relation("AuditActor")
  targetLogs    AuditLog[]       @relation("AuditTarget")
  accounts      Account[]
  sessions      Session[]
  courseAudits  CourseAuditLog[]
}

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
  PLATFORM_MANAGER
  SYSTEM_MANAGER
  OPERATIONS_MANAGER
}

enum UserStatus {
  STUDENT
  TEACHER
  ALUMNI
}

enum DegreeLevel {
  BACHELOR
  MASTER
  DOCTORAL
}

model Faculty {
  id        String   @id @default(cuid())
  name      String
  nameTh    String
  createdAt DateTime @default(now())

  curricula Curriculum[]
  courses   Course[]
}

model Curriculum {
  id             String      @id @default(cuid())
  facultyId      String
  programType    ProgramType
  curriculumYear Int
  createdAt      DateTime    @default(now())

  faculty Faculty  @relation(fields: [facultyId], references: [id])
  courses Course[]
}

enum ProgramType {
  REGULAR
  INTERNATIONAL
}

model Course {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  nameTh         String
  codeEn         String   @default("") // รหัสย่อ (EN)
  codeTh         String   @default("") // รหัสย่อ (TH)
  credits        String   @default("")
  description    String   @default("")
  descriptionEn  String   @default("") // คำอธิบายวิชา (อังกฤษ)
  prerequisite   String   @default("") // Prerequisite
  department     String   @default("") // คณะ/หน่วยงาน
  updatedDate    String   @default("") // วันที่อัปเดต
  isFreeElective Boolean  @default(false)
  facultyId      String
  curriculumId   String
  createdAt      DateTime @default(now())

  faculty    Faculty          @relation(fields: [facultyId], references: [id])
  curriculum Curriculum       @relation(fields: [curriculumId], references: [id])
  ratings    DifficultyRating[]
  reviewRoom ReviewRoom?
  auditLogs  CourseAuditLog[]
}

model CourseAuditLog {
  id        String   @id @default(cuid())
  courseId  String
  adminId   String
  action    String
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])
  admin  User   @relation(fields: [adminId], references: [id])
}

model ReviewRoom {
  id        String   @id @default(cuid())
  courseId  String   @unique
  createdAt DateTime @default(now())

  course   Course    @relation(fields: [courseId], references: [id])
  messages Message[]
}

model Message {
  id                  String       @id @default(cuid())
  roomId              String
  userId              String
  content             String
  isDeleted           Boolean      @default(false)
  wasAnonymous        Boolean?
  senderStatus        UserStatus?
  senderYearOfStudy   Int?
  senderDegreeLevel   DegreeLevel? // new: snapshot ระดับปริญญา ณ เวลาส่ง
  senderFaculty       String?      // new: snapshot คณะ ณ เวลาส่ง
  senderAlumniYear    Int?         // new: snapshot รุ่นที่จบ ณ เวลาส่ง
  editedAt            DateTime?
  createdAt           DateTime     @default(now())

  room ReviewRoom @relation(fields: [roomId], references: [id])
  user User       @relation(fields: [userId], references: [id])

  @@index([roomId, createdAt])
  @@index([roomId, isDeleted, createdAt])
}

model DifficultyRating {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
  @@index([courseId])
}

model Report {
  id           String   @id @default(cuid())
  userId       String?
  content      String
  systemRating Int
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  targetId  String
  action    String
  createdAt DateTime @default(now())

  actor  User @relation("AuditActor", fields: [actorId], references: [id])
  target User @relation("AuditTarget", fields: [targetId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
